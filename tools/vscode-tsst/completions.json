  {
    "label": "calculator",
    "kind": "snippet",
    "detail": "interactive calculator starter",
    "insertText": "use \"quartus:math\";\nuse \"quartus:ui\";\n\nfcn calculate (cre_int a, cre_int b, cre_str op) -> int {\n\tif op == \"add\" || op == \"+\" {\n\t\treturn a + b;\n\t}\n\n\tif op == \"subtract\" || op == \"-\" {\n\t\treturn a - b;\n\t}\n\n\tif op == \"multiply\" || op == \"*\" {\n\t\treturn a * b;\n\t}\n\n\tif op == \"divide\" || op == \"/\" {\n\t\treturn a / b;\n\t}\n\n\treturn 0;\n}\n\npub fcn main () {\n\tq_ui_app_start(\"Calculator\");\n\n\tcre_int a = input_int(\"First number: \");\n\tcre_str op = lower(trim(input_str(\"Operation: \")));\n\tcre_int b = input_int(\"Second number: \");\n\n\tq_ui_number(\"Result\", calculate(a, b, op));\n\n\tq_ui_app_end();\n}"
  }
